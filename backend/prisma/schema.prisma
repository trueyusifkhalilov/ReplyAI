generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  plan        String   @default("starter")
  aiEngine    String   @default("claude")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  profile     CompanyProfile?
  messages    Message[]
  faqs        FAQ[]
  sources     Source[]
  users       User[]
  platforms   PlatformConnection[]
}

model CompanyProfile {
  id              String  @id @default(cuid())
  companyId       String  @unique
  company         Company @relation(fields: [companyId], references: [id])

  tone            String  @default("friendly")
  useEmoji        Boolean @default(true)
  signOff         String  @default("")
  workHours       String  @default("B.e-Cüm: 09:00-18:00")
  defaultLanguage String  @default("az")
  systemPrompt    String  @default("")
  escEmail        String  @default("")
  escWhatsapp     String  @default("")
  escWebhookUrl   String  @default("")
  autoReply       Boolean @default(true)
  autoEscalate    Boolean @default(true)
}

model User {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  email     String
  password  String
  role      String   @default("agent")
  name      String
  createdAt DateTime @default(now())
}

model Message {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])

  platform       String
  externalId     String?
  senderName     String?
  senderId       String?
  text           String
  intent         String?
  intentConf     String?
  language       String   @default("az")
  aiReply        String?
  status         String   @default("pending")
  escalated      Boolean  @default(false)
  deliveryStatus String?

  createdAt      DateTime @default(now())
}

model FAQ {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  question  String
  answer    String
  tags      String  @default("")
}

model Source {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  type      String
  label     String
  content   String  @default("")
  createdAt DateTime @default(now())
}

model PlatformConnection {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  platform    String
  accessToken String  @default("")
  pageId      String  @default("")
  isActive    Boolean @default(false)
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
